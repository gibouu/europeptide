# Copy to .env and fill in. NEVER commit .env — the repo is public.
# Use your Mollie test key (test_...) in dev; the live key only ever goes
# into the production host's secret store.
MOLLIE_API_KEY=
PORT=3001
# Set when the server is reachable from the internet, so Mollie webhooks work:
# PUBLIC_URL=https://yourdomain.com
